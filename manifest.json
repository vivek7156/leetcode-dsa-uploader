{
  "manifest_version": 3,
  "name": "DSA Uploader",
  "version": "0.1.0",
  "description": "Capture LeetCode submissions and prepare them for upload.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs",
    "downloads",
    "cookies"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*"
  ],
  "options_page": "src/ui/options.html",
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "DSA Uploader",
    "default_popup": "src/ui/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/progress*"
      ],
      "js": [
        "dist/content/leetcode/page.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dist/injected/network-hook.js"
      ],
      "matches": [
        "https://leetcode.com/*"
      ]
    }
  ]
}